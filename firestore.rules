rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/roles/admins/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/admins/users/$(request.auth.uid)).data.enabled == true;
    }

    function validBookingCreate() {
      return request.resource.data.keys().hasAll([
          "bookingRef", "guestName", "email", "phone", "roomId", "roomName", "nightlyPrice",
          "totalPrice", "guestCount", "checkIn", "checkOut", "nights", "status", "paymentStatus",
          "paymentMethod", "isActive", "lockDates", "createdAt", "updatedAt", "userId"
        ]) &&
        request.resource.data.guestName is string &&
        request.resource.data.email is string &&
        request.resource.data.phone is string &&
        request.resource.data.roomId is string &&
        request.resource.data.roomName is string &&
        request.resource.data.bookingRef is string &&
        request.resource.data.nightlyPrice is number &&
        request.resource.data.totalPrice is number &&
        request.resource.data.guestCount is int &&
        request.resource.data.nights is int &&
        request.resource.data.status == "pending" &&
        request.resource.data.paymentStatus == "unpaid" &&
        request.resource.data.isActive == true &&
        request.resource.data.userId ==
          (request.auth != null ? request.auth.uid : null);
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if validBookingCreate();
      allow update, delete: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookingLocks/{lockId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(["bookingId", "bookingRef", "roomId", "date", "status", "createdAt"]) &&
        request.resource.data.bookingId is string &&
        request.resource.data.roomId is string &&
        request.resource.data.date is string &&
        request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    match /meta/bookingCounter {
      allow get: if true;
      allow create, update: if request.resource.data.keys().hasOnly(["value"]) &&
        request.resource.data.value is int &&
        request.resource.data.value >= 0;
      allow delete: if false;
    }

    match /roles/admins/users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
